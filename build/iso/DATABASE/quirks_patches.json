{
  "quirks": {
    "kernel_quirks": {
      "AppleCpuPmCfgLock": {
        "description": "Lock AppleIntelCPUPowerManagement cfg lock",
        "cpu": ["SandyBridge", "IvyBridge", "Haswell"],
        "default": false,
        "warning": "Enable only if CPU power management doesn't work"
      },
      "AppleXcpmCfgLock": {
        "description": "Lock XCPM cfg lock",
        "cpu": ["SandyBridge", "IvyBridge", "Haswell"],
        "default": false
      },
      "AppleXcpmExtraMsrs": {
        "description": "Extra MSRs for XCPM",
        "cpu": ["Broadwell", "Skylake", "KabyLake"],
        "default": false
      },
      "AppleXcpmForceBoost": {
        "description": "Force maximum CPU frequency",
        "cpu": ["all"],
        "default": false,
        "warning": "May cause high power consumption"
      },
      "CpuTscSync": {
        "description": "Synchronize TSC across cores",
        "cpu": ["SandyBridge", "IvyBridge", "Haswell", "Broadwell", "Skylake", "KabyLake", "CoffeeLake"],
        "default": true,
        "critical": true,
        "description_detailed": "CRITICAL: Without this, system may hang or boot slowly"
      },
      "DisableIOMapper": {
        "description": "Disable IOMapper",
        "cpu": ["AMD"],
        "default": true,
        "required_amd": true
      },
      "DisableRtcChecksum": {
        "description": "Disable RTC checksum",
        "cpu": ["all"],
        "default": false,
        "description_detailed": "Prevents RTC errors on some boards"
      },
      "ExternalDiskIcons": {
        "description": "Enable external disk icons",
        "cpu": ["AMD", "SandyBridge", "IvyBridge"],
        "default": true,
        "required_legacy": true
      },
      "IncreasePciBarSize": {
        "description": "Increase PCI BAR size to 256MB",
        "cpu": ["all"],
        "default": false,
        "warning": "May break some GPUs"
      },
      "LapicKernelPanic": {
        "description": "Disable LAPIC kernel panic",
        "cpu": ["HP notebooks"],
        "default": false
      },
      "LegacyCommpage": {
        "description": "Use legacy commpage",
        "cpu": ["all"],
        "default": false,
        "min_os": "10.6",
        "max_os": "10.9"
      },
      "PanicNoKextDump": {
        "description": "Don't dump kext info on panic",
        "cpu": ["all"],
        "default": true,
        "recommended": true
      },
      "PowerTimeoutKernelPanic": {
        "description": "Fix power timeout kernel panic",
        "cpu": ["all"],
        "default": true,
        "critical": true,
        "description_detailed": "CRITICAL: Required for AppleIntelPowerClamp to work"
      },
      "ProcInfo": {
        "description": "Enable proc info",
        "cpu": ["AMD"],
        "default": false
      },
      "SetApfsTrimTimeout": {
        "description": "Set APFS trim timeout",
        "cpu": ["all"],
        "default": "0",
        "value_type": "integer"
      },
      "ThirdPartyDrives": {
        "description": "Enable third-party drive support",
        "cpu": ["all"],
        "default": true,
        "required_legacy": true
      },
      "XhciPortLimit": {
        "description": "Enable XHCI port limit patch",
        "cpu": ["all"],
        "default": true,
        "critical": true,
        "description_detailed": "CRITICAL: Enables more than 15 USB ports"
      },
      "ZlibMemoryLimit": {
        "description": "Set zlib memory limit",
        "cpu": ["all"],
        "default": "0",
        "value_type": "integer"
      }
    },
    
    "acpi_quirks": {
      "FadtEnableReset": {
        "description": "Enable FADT reset register",
        "cpu": ["all"],
        "default": false,
        "legacy_only": true
      },
      "FadtNoWb": {
        "description": "FADT no write back",
        "cpu": ["all"],
        "default": false
      },
      "NormalizeHeaders": {
        "description": "Normalize ACPI headers",
        "cpu": ["all"],
