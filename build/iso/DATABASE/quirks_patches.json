      },
      "ReconnectOnResChange": {
        "description": "Reconnect on resolution change",
        "cpu": ["all"],
        "default": false
      },
      "RefuseToLoad": {
        "description": "Refuse to load",
        "cpu": ["all"],
        "default": false
      },
      "ReloadOptionRoms": {
        "description": "Reload option ROMs",
        "cpu": ["all"],
