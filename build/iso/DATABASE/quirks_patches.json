  "special_patches": {
    "TSC_Sync_Patch": {
      "name": "TSC Sync Patch",
      "description": "Synchronize TSC across all CPU cores",
      "find": "0F 30 48 3B",
      "replace": "90 90 48 3B",
      "target": "AppleIntelPowerClamp",
      "min_os": "10.8",
      "cpu": ["SandyBridge", "IvyBridge", "Haswell", "Broadwell"]
    },
    "AppleIntelCPU_Patch": {
      "name": "AppleIntelCPU Power Management Patch",
      "description": "Enable XCPM for unsupported CPUs",
      "find": "0F B6 48 10",
      "replace": "90 90 90 90",
      "target": "AppleIntelCPUPowerManagement",
      "cpu": ["all"]
    },
    "MTRR_Warning_Patch": {
      "name": "MTRR Warning Fix",
      "description": "Fix MTRR warning",
      "find": "0F 85 8A 01 00 00",
      "replace": "0F 83 8A 01 00 00",
      "target": "kernel",
      "min_os": "10.13"
    },
    "HPET_Patch": {
      "name": "HPET Fix",
      "description": "Fix HPET for laptops",
      "find": "48 8B 05 00 00 00 00",
      "replace": "48 8B 05 00 00 00 00",
      "target": "AppleHPET",
      "cpu": ["all"]
    },
    "XHCI_Controller_Patch": {
      "name": "XHCI Controller Patch",
      "description": "Enable XHCI controller",
      "find": "0F B6 48 10",
      "replace": "90 90 48 10",
      "target": "IOUSBHostDevice",
      "min_os": "10.11"
    },
    "RTC_Checksum_Patch": {
      "name": "RTC Checksum Patch",
      "description": "Disable RTC checksum",
      "find": "0F B6 48 10",
      "replace": "90 90 90 90",
      "target": "AppleRTC",
      "description_detailed": "Prevents RTC errors on some motherboards"
    },
    "AppleAHCIPort_Reset_Patch": {
      "name": "AHCI Port Reset",
      "description": "Reset AHCI ports on boot",
      "find": "0F B6 48 10",
      "replace": "90 90 90 90",
      "target": "AppleAHCIPort"
    },
    "LegacyCPU_Patch": {
      "name": "Legacy CPU Patch",
      "description": "Enable legacy CPU support",
      "find": "0F B6 50 10",
      "replace": "90 90 90 90",
      "target": "AppleIntelCPUPowerManagement",
      "cpu": ["Pentium4", "Core2", "Conroe", "Merom"],
      "min_os": "10.4",
      "max_os": "10.7"
    },
    "TSC2_Patch": {
      "name": "TSC2 Patch for Legacy CPUs",
      "description": "Fix TSC for non-Apple CPUs",
      "find": "0F 30 C3 90",
      "replace": "0F 30 90 90",
      "target": "kernel",
      "cpu": ["Pentium4", "Core2", "AMD-K8", "AMD-K10"]
    },
    "P-State_Patch": {
      "name": "P-State Patch for AMD",
      "description": "Enable P-State for AMD CPUs",
      "find": "0F B6 48 10",
      "replace": "90 90 90 90",
      "target": "AppleIntelCPUPowerManagement",
      "cpu": ["AMD-K8", "AMD-K10", "AMD-Bulldozer"]
    },
    "MSRTools_Patch": {
      "name": "MSR Tools Patch",
      "description": "Enable MSR access for AMD",
      "find": "0F 30 48 3B",
      "replace": "90 90 48 3B",
      "target": "AppleIntelPowerClamp",
      "cpu": ["AMD-K8", "AMD-K10", "AMD-Bulldozer"]
    },
    "LapicKernelPanic_Patch": {
      "name": "LAPIC Kernel Panic Fix",
      "description": "Fix LAPIC kernel panic on HP laptops",
      "find": "0F 30 C3 90",
      "replace": "90 90 90 90",
      "target": "kernel",
      "cpu": ["all"],
      "description_detailed": "Common on HP notebooks with SandyBridge+"
    },
    "IOConsole_Patch": {
      "name": "IOConsole Fix",
      "description": "Fix IOConsole for legacy GPUs",
      "find": "0F B6 48 10",
      "replace": "90 90 90 90",
      "target": "IOConsole",
      "cpu": ["Pentium4", "Core2", "Conroe", "Merom"]
    },
    "Framebuffer_Patch": {
      "name": "Framebuffer Patch",
      "description": "Enable legacy framebuffer",
      "find": "0F B6 48 10",
      "replace": "90 90 90 90",
      "target": "IOFramebuffer",
      "cpu": ["all"]
    },
    "IGPU_Patch": {
      "name": "Integrated GPU Patch",
      "description": "Enable integrated GPU for legacy CPUs",
      "find": "0F B6 48 10",
      "replace": "90 90 90 90",
      "target": "IntelAccelerator",
      "cpu": ["SandyBridge", "IvyBridge"]
    },
    "AppleHDA_Patch": {
      "name": "AppleHDA Patch for Legacy",
      "description": "Fix AppleHDA for legacy codecs",
      "find": "0F B6 48 10",
      "replace": "90 90 90 90",
      "target": "AppleHDA",
      "cpu": ["all"]
    },
    "AppleACPIPlatform_Patch": {
      "name": "ACPI Platform Patch",
      "description": "Fix ACPI for legacy boards",
      "find": "0F B6 48 10",
      "replace": "90 90 90 90",
      "target": "AppleACPIPlatform",
      "cpu": ["Pentium4", "Core2", "Conroe", "Merom"]
    },
    "RTC_Patch_Legacy": {
      "name": "RTC Legacy Patch",
      "description": "Fix RTC for legacy motherboards",
      "find": "0F B6 48 10",
      "replace": "90 90 90 90",
      "target": "AppleRTC",
      "cpu": ["Pentium4", "Core2", "AMD-K8", "AMD-K10"]
    }
  },
  
